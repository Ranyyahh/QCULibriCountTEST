-- TRIGGERS guys
CREATE OR REPLACE TRIGGER trg_admin_id
BEFORE INSERT ON admin
FOR EACH ROW
BEGIN
    IF :NEW.admin_id IS NULL THEN
        SELECT seq_admin_id.NEXTVAL INTO :NEW.admin_id FROM DUAL;
    END IF;
END;
/

